<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Porsche 356 Parts — Vancouver, BC" }}</title>
  <meta name="description" content="{{ description or 'Surplus parts from a Porsche 356 restoration project. Vancouver, BC. Canada only.' }}">
  <link rel="stylesheet" href="{{ '/assets/css/main.css' | url }}">
</head>
<body>
  <header class="site-header">
    <a href="{{ '/' | url }}" class="site-logo">
      <span class="logo-mark">356</span>
      <span class="logo-text">Parts / Vancouver</span>
    </a>
    <nav class="site-nav">
      <a href="{{ '/' | url }}">Listing</a>
      <a href="{{ '/' | url }}#contact">Contact</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>Porsche 356 restoration surplus &mdash; Vancouver, BC &mdash; Canada only</p>
    <p class="footer-note">Not affiliated with Porsche AG. All parts sold as-is.</p>
  </footer>
